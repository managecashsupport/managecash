generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PUBLIC SCHEMA (Platform-wide) ───────────────────────

model Tenant {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId                  String    @unique @map("shop_id") @db.VarChar(50)
  shopName                String    @map("shop_name") @db.VarChar(200)
  ownerEmail              String    @unique @map("owner_email") @db.VarChar(200)
  ownerName               String    @map("owner_name") @db.VarChar(200)
  plan                    String    @default("starter") @db.VarChar(50)
  status                  String    @default("trial") @db.VarChar(50)
  razorpaySubscriptionId  String?   @map("razorpay_subscription_id") @db.VarChar(200)
  trialEndsAt             DateTime? @map("trial_ends_at") @db.Timestamptz
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("tenants")
}

model Plan {
  id                        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String  @unique @db.VarChar(50)
  priceMonthly              Int     @map("price_monthly")
  priceYearly               Int     @map("price_yearly")
  maxUsers                  Int     @map("max_users")
  maxTransactionsPerMonth   Int     @map("max_transactions_per_month")
  razorpayPlanIdMonthly     String? @map("razorpay_plan_id_monthly") @db.VarChar(200)
  razorpayPlanIdYearly      String? @map("razorpay_plan_id_yearly") @db.VarChar(200)

  @@map("plans")
}

// ─── TENANT SCHEMAS (Dynamic, created at runtime) ───────────────────────
